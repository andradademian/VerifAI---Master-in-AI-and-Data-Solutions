# VerifAI — environment configuration (copy to .env and fill in)
# Everything here is OPTIONAL for the UX/UI demo. With none of it set, the app
# runs in DEMO mode: bundled sample articles + a placeholder credibility score,
# which is enough to demo the full user experience.

# --- Live news (Explore tab) ---------------------------------------------
# Without this, the Explore tab serves bundled demo articles.
# Get a free key at https://newsdata.io
NEWSDATA_API_KEY=
NEWS_API_BASE_URL=https://newsdata.io/api/1/latest

# --- AI explanation (optional) -------------------------------------------
# Powers the friendly "AI Explanation" text in the analysis modal (Cohere).
# Without it, scoring still works; the explanation section is just skipped.
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025

# --- Server --------------------------------------------------------------
# macOS often occupies port 5000 (AirPlay Receiver). Use 5001 to avoid it.
PORT=5001
FLASK_DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# Note: the real fake-news model (DistilBERT) also needs `torch` and
# `transformers` installed and the model weights present in
# ../distilbert_frozen_hf. Without them the app shows a placeholder score.
